@echo off

REM 词法分析器运行脚本（GUI版本）
cls
echo ====================================================
echo         词法分析器运行脚本（GUI版本）
echo ====================================================
echo.

REM 检查可执行文件是否存在
if not exist 词法分析器.exe (
    echo 错误：找不到词法分析器.exe文件！
    echo 请运行"编译GUI应用.bat"来编译程序。
    pause
    exit /b 1
)

REM 显示当前目录下的测试文件
echo 当前目录中的测试文件：
dir /b *.txt | findstr /v "README.txt 编译说明.txt 编译指南.txt"
echo.
echo ====================================================
echo 使用说明：
echo 1. 在图形界面中输入您要分析的文件名（如：program1.txt）
echo 2. 点击"开始词法分析"按钮
3. 分析完成后，会显示结果信息
====================================================
echo.

REM 启动GUI版本的词法分析器
echo 正在启动词法分析器图形界面...
start "词法分析器" "词法分析器.exe"

echo 词法分析器已启动，请查看程序窗口。
pause > nul